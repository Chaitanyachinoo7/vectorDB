[requires]
python_version = "3.10"

[packages]
fastapi = ">=0.115,<0.116"
uvicorn = {extras = ["standard"], version = ">=0.30,<0.31"}
pydantic = ">=2.7,<3"
pydantic-settings = ">=2.3,<3"
pydantic-ai-slim = {extras = ["openai"], version = ">=1,<2"}
chromadb = ">=0.5,<1"
numpy = ">=1.26,<3"
scikit-learn = ">=1.4,<2"

[dev-packages]
pytest = ">=8,<9"
ruff = ">=0.5,<1"

[scripts]
dev = "uvicorn app.main:app --reload --host 0.0.0.0 --port 8000"
test = "pytest -q"
lint = "ruff check ."
format = "ruff format ."
